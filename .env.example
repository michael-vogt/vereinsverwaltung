# ──────────────────────────────────────────────────────
# Datenquelle – genau EINE Option aktivieren (auskommentieren)
# ──────────────────────────────────────────────────────

# Option A: Lokale Datei
# DB_SOURCE=local
# LOCAL_DB_PATH=./data.db          # relativer oder absoluter Pfad

# Option B: FTP / FTPS
# DB_SOURCE=ftp
# FTP_HOST=ftp.meinverein.de
# FTP_USER=meinbenutzer
# FTP_PASSWORD=geheimespasswort
# FTP_PATH=/vereinsverwaltung/data.db
# FTP_USE_TLS=false                # true für explizites FTPS

# ──────────────────────────────────────────────────────
# Gemeinsame Einstellungen
# ──────────────────────────────────────────────────────

# Sync-Intervall in Sekunden (Standard: 300 = 5 Minuten)
SYNC_INTERVAL=300
